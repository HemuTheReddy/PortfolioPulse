# ═══════════════════════════════════════════════════════════════════════
#  PortfolioPulse — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════
#  Copy this file to .env (backend) and frontend/.env.local (frontend).
#  NEVER commit real values to git.
# ═══════════════════════════════════════════════════════════════════════


# ─── AWS Credentials ─────────────────────────────────────────────────
# IAM Console → Users → Security credentials → Access keys
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
DYNAMO_TABLE=MarketState

# ─── Moralis (required — on-chain metadata for ERC-20 tokens) ───────
MORALIS_API_KEY=your_moralis_key_here

# ─── CoinGecko (optional — higher rate limits with Pro key) ─────────
# COINGECKO_API_KEY=your_coingecko_key_here

# ─── Covalent (optional — alternative to Moralis) ───────────────────
# COVALENT_API_KEY=your_covalent_key_here

# ─── Ethereum RPC (optional — default: public RPCs) ─────────────────
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Coinbase OAuth ─────────────────────────────────────────────────
COINBASE_CLIENT_SECRET=your_coinbase_client_secret_here
COINBASE_REDIRECT_URI=http://localhost:3000/api/auth/coinbase/callback


# ═══════════════════════════════════════════════════════════════════════
#  FRONTEND  (copy these into frontend/.env.local)
# ═══════════════════════════════════════════════════════════════════════

# API URL — local dev: http://localhost:8000
#         — production: your API Gateway URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# WalletConnect — https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Mobula — wallet data ingestion
NEXT_PUBLIC_MOBULA_KEY=your_mobula_key_here

# Coinbase OAuth (public client ID)
NEXT_PUBLIC_COINBASE_CLIENT_ID=your_coinbase_client_id_here
